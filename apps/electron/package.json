{
  "name": "@code-review-app/electron",
  "private": true,
  "version": "0.1.5",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "dotenv -- electron-vite dev --watch",
    "build": "tsc --noEmit --project ../../tsconfig.json && electron-vite build",
    "dist": "electron-builder",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@hadeeb/trpc-worker": "catalog:",
    "@libsql/client": "catalog:",
    "@code-review-app/backend": "workspace:*",
    "@code-review-app/frontend": "workspace:*",
    "@code-review-app/shared": "workspace:*",
    "@trpc/server": "catalog:",
    "effect": "catalog:",
    "electron-updater": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/ws": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "dotenv-cli": "catalog:",
    "electron": "catalog:",
    "electron-builder": "catalog:",
    "electron-vite": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "build": {
    "appId": "app.code-review",
    "productName": "code-review.app",
    "directories": {
      "output": "../../release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json",
      {
        "from": "../../packages/backend/drizzle",
        "to": "drizzle",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icons/icon.icns",
      "entitlements": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icons",
      "desktop": {
        "entry": {
          "Type": "Application",
          "Name": "code-review.app",
          "Comment": "Browse GitHub and GitLab pull requests locally",
          "Exec": "code-review.app %U",
          "Icon": "code-review.app",
          "Terminal": "false",
          "Categories": "Development;Utility;",
          "MimeType": "x-scheme-handler/code-review.app;",
          "StartupWMClass": "code-review.app"
        }
      }
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icons/icon.ico"
    },
    "protocols": [
      {
        "name": "code-review.app",
        "schemes": [
          "code-review.app"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "tarik02",
        "repo": "code-review.app"
      }
    ],
    "generateUpdatesFilesForAllChannels": false
  }
}
