{
  "name": "rudu",
  "private": true,
  "version": "0.1.5",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "dist": "electron-builder",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@effect/platform-node": "^0.106.0",
    "@fontsource/geist-mono": "^5.2.7",
    "@hadeeb/trpc-worker": "^0.1.0",
    "@heroicons/react": "^2.2.0",
    "@pierre/diffs": "^1.1.17",
    "@pierre/trees": "0.0.1-beta.4",
    "@pierre/truncate": "^0.0.2",
    "@tanstack/react-query": "^5.90.3",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "better-sqlite3": "^12.9.0",
    "effect": "^3.21.2",
    "electron-updater": "^6.8.3",
    "fuse.js": "^7.3.0",
    "markdown-to-jsx": "^9.7.15",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shiki": "^4.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "6.0.0-beta.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.tanvesh.rudu",
    "productName": "rudu",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icons/icon.icns",
      "entitlements": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icons"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icons/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "tanvesh01",
        "repo": "rudu"
      }
    ],
    "generateUpdatesFilesForAllChannels": false
  }
}
